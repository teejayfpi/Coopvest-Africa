# Coopvest Africa - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
NODE_ENV=development
PORT=8080

# ==============================================================================
# DATABASE CONFIGURATION (SUPABASE)
# ==============================================================================
# MongoDB is no longer used. Data persistence is handled via Supabase PostgreSQL.
# No MONGODB_URI required.

# ==============================================================================
# JWT SECURITY - CRITICAL FOR AUTHENTICATION
# ==============================================================================
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production-at-least-32-characters
JWT_EXPIRES_IN=7d

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
# List allowed origins separated by commas (no spaces)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,https://admin.coopvestafrica.org,https://coopvest.com

# ==============================================================================
# REFERRAL SYSTEM SETTINGS
# ==============================================================================
REFERRAL_LOCK_IN_DAYS=30
REFERRAL_MIN_SAVINGS_MONTHS=3
REFERRAL_MIN_SAVINGS_AMOUNT=5000
REFERRAL_MIN_INTEREST_FLOOR_QUICK_LOAN=5.0
REFERRAL_MIN_INTEREST_FLOOR_FLEXI_LOAN=6.0
REFERRAL_MIN_INTEREST_FLOOR_EMERGENCY_LOAN=7.0
REFERRAL_MIN_INTEREST_FLOOR_BUSINESS_LOAN=8.0

# ==============================================================================
# RATE LIMITING
# ==============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================================================
# ADMIN PORTAL IP WHITELIST
# ==============================================================================
# Comma-separated list of allowed IP addresses for admin access
# Use empty string to allow all IPs (not recommended for production!)
ADMIN_IP_WHITELIST=

# ==============================================================================
# SSL/TLS CONFIGURATION
# ==============================================================================
ENFORCE_HTTPS=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================
LOG_LEVEL=info
LOG_DIR=./logs
LOG_TO_FILE=true
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=30

# ==============================================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ==============================================================================
# For Gmail with App Password:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=coopvestafrica@gmail.com
SMTP_PASS=uaixvhqppmbvtyxc
EMAIL_FROM=noreply@coopvestafrica.org

# ==============================================================================
# API URL FOR QR CODE GENERATION & LINKS
# ==============================================================================
# Since coopvestafrica.com is not live, use your local IP or tunnel (like ngrok)
# For local testing with mobile: http://<your-computer-ip>:8080
API_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# ==============================================================================
# GOOGLE AUTHENTICATION
# ==============================================================================
GOOGLE_CLIENT_ID=1040576298736-991ja94slls4f6csarfheerlkg7bfpon.apps.googleusercontent.com

# ==============================================================================
# SUPABASE CONFIGURATION
# ==============================================================================
# Get these from: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ==============================================================================
# FIREBASE CLOUD MESSAGING (FCM) — Push Notifications
# ==============================================================================
# Required for sending push notifications via notifyService.sendPush()
# Get these from: Firebase Console > Project Settings > Service Accounts >
#                 Generate new private key (download JSON, copy values below)
#
# Option A — individual env vars (recommended for CI/hosting platforms):
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
# Paste the private_key value from the JSON. Keep the \n literal (most platforms
# store it escaped; the notifyService will convert \n → newline at runtime).
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Option B — path to the downloaded service-account JSON file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# When neither option is configured the push channel is skipped gracefully
# and all other channels (in_app, email, sms) continue to work normally.
