# Coopvest Africa - Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
NODE_ENV=production
PORT=8080

# ==============================================================================
# MONGODB CONNECTION
# ==============================================================================
# For MongoDB Atlas (recommended for production):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/coopvest?retryWrites=true&w=majority
# MONGODB_URI=mongodb+srv://coopvestafrica_db_user:temiloluwa@coopvest.tzh9orz.mongodb.net/?appName=Coopvest
MONGODB_URI=mongodb://localhost:27017/coopvest

# ==============================================================================
# JWT SECURITY - CRITICAL FOR AUTHENTICATION
# ==============================================================================
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=HscBKdg8TQSKtQpIdoBxoF6XW9N9H7bWQmKK4F49gT0aj7AuR140+7LlZXOlrxx0OsyDKfYA7uCj+5ZHNtX62A==
JWT_EXPIRES_IN=7d

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
# List allowed origins separated by commas (no spaces)
CORS_ORIGIN=http://localhost:3000,http://localhost:8080,https://admin.coopvestafrica.org,https://coopvest.com

# ==============================================================================
# REFERRAL SYSTEM SETTINGS
# ==============================================================================
REFERRAL_LOCK_IN_DAYS=30
REFERRAL_MIN_SAVINGS_MONTHS=3
REFERRAL_MIN_SAVINGS_AMOUNT=5000
REFERRAL_MIN_INTEREST_FLOOR_QUICK_LOAN=5.0
REFERRAL_MIN_INTEREST_FLOOR_FLEXI_LOAN=6.0
REFERRAL_MIN_INTEREST_FLOOR_EMERGENCY_LOAN=7.0
REFERRAL_MIN_INTEREST_FLOOR_BUSINESS_LOAN=8.0

# ==============================================================================
# RATE LIMITING
# ==============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==============================================================================
# ADMIN PORTAL IP WHITELIST
# ==============================================================================
# Comma-separated list of allowed IP addresses for admin access
# Use empty string to allow all IPs (not recommended for production!)
ADMIN_IP_WHITELIST=

# ==============================================================================
# SSL/TLS CONFIGURATION
# ==============================================================================
ENFORCE_HTTPS=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================
LOG_LEVEL=info
LOG_DIR=./logs
LOG_TO_FILE=true
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=30

# ==============================================================================
# EMAIL CONFIGURATION (Gmail SMTP)
# ==============================================================================
# For Gmail with App Password:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=coopvestafrica@gmail.com
SMTP_PASS=gmlusilpuzcafsbl
EMAIL_FROM=noreply@coopvestafrica.org

# ==============================================================================
# API URL FOR QR CODE GENERATION & LINKS
# ==============================================================================
# Since coopvestafrica.com is not live, use your local IP or tunnel (like ngrok)
# For local testing with mobile: http://<your-computer-ip>:8080
API_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# ==============================================================================
# GOOGLE AUTHENTICATION
# ==============================================================================
GOOGLE_CLIENT_ID=1040576298736-991ja94slls4f6csarfheerlkg7bfpon.apps.googleusercontent.com

# ==============================================================================
# ADMIN DASHBOARD SYNC (Cross-backend service token)
