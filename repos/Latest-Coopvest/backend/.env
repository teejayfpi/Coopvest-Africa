RATE_LIMIT_MAX_REQUESTS=100

# ==============================================================================
# ADMIN PORTAL IP WHITELIST
# ==============================================================================
ADMIN_IP_WHITELIST=

# ==============================================================================
# SSL/TLS CONFIGURATION
# ==============================================================================
ENFORCE_HTTPS=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================
LOG_LEVEL=info
LOG_DIR=./logs
LOG_TO_FILE=true
LOG_MAX_SIZE=10485760
LOG_MAX_FILES=30

