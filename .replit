modules = ["nodejs-20"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Coopvest API Server"

[[workflows.workflow]]
name = "Coopvest API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node artifacts/api-server/src/index.js"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5173
externalPort = 80
